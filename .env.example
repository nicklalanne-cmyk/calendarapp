# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth client (same client configured in Supabase Auth -> Providers -> Google)
# Used server-side to refresh Google access tokens for Calendar API calls.
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The site URL (used for OAuth redirects). In Vercel set to your deployment URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
