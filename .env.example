# Copy to .env.local for local dev. In production these live in
# Vercel > cadence > Settings > Environment Variables.
#
# Anything prefixed NEXT_PUBLIC_ is compiled into the browser bundle and is
# PUBLIC. Everything else is server-only and must never be exposed.

# --- Supabase (Project Settings -> API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses row-level security. Used ONLY by /api/cron/reminders,
# which needs to read every user's tasks to send background notifications.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (same client set in Supabase Auth -> Providers -> Google) --
# Used server-side to refresh Google access tokens for Calendar API calls.
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- The AI assistant + voice-memo transcript cleanup -----------------------
ANTHROPIC_API_KEY=sk-ant-...
# Optional. Defaults to claude-sonnet-5.
CADENCE_AI_MODEL=claude-sonnet-5

# --- Background web push ----------------------------------------------------
# Generate a pair with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>` so nobody
# else can trigger the reminder job.
CRON_SECRET=some-long-random-string

# --- Misc -------------------------------------------------------------------
# The site URL (used for OAuth redirects). In Vercel set to your deployment URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
